# PartyKit server host
# Use .env.development for local (localhost:1999)
# Use .env.production for prod (your-app.partykit.dev)
VITE_PARTYKIT_HOST=localhost:1999

# Movement network: "mainnet" or "testnet"
VITE_MOVEMENT_NETWORK=mainnet

# Chess game contract address
VITE_CHESS_CONTRACT_ADDRESS=0x2e7cd46d8adf921b4057fbf3c9b127f6385f0b29ff169b4673b7ffcea235cb57
